{
  "$schema": "../../schemas/theme.schema.json",
  "name": "Genshin Login WebGL",
  "id": "genshin-login-webgl",
  "author": "www-genshin contributors / SDDM integration",
  "version": "0.1.0",
  "compatibility": { "platform": ">=0.1.0", "qt": ">=6.5", "quick3d": ">=6.5" },
  "scene": { "file": "web/index.html", "format": "webgl", "async": true, "initialCamera": "webgl" },
  "animations": {
    "Idle": { "clip": "Idle", "loop": true },
    "EnterLogin": { "clip": "EnterLogin", "durationMs": 100 },
    "LoginFailed": { "clip": "LoginFailed", "durationMs": 300 },
    "AuthenticationProcessing": { "clip": "OpenDoor", "durationMs": 2200 }
  },
  "authentication": {},
  "environment": {},
  "scripts": [],
  "events": {},
  "overlay": {
    "mode": "custom",
    "component": "overlay/GenshinLoginOverlay.qml",
    "anchor": "center",
    "targetNode": null,
    "sizeEditable": false,
    "slots": [
      { "key": "logo", "type": "image", "label": "Logo do painel", "group": "Painel", "default": "ui-assets/logo_hoyoverse_default.png", "options": ["ui-assets/genshin-logo.png"] },
      { "key": "panelColor", "type": "color", "label": "Cor do cartão", "group": "Painel", "default": "#fffefd" },
      { "key": "cardBackgroundImage", "type": "image", "label": "Imagem de fundo do cartão", "group": "Painel", "default": "", "options": ["ui-assets/painelgenshin.png", "ui-assets/paineldeslogado.png"] },
      { "key": "font", "type": "font", "label": "Fonte do tema", "group": "Painel", "default": "ui-assets/sdk-jp-unity.ttf", "options": ["ui-assets/sdk-sc-unity.ttf", "ui-assets/genshin-ui.ttf", "ui-assets/title-original/Login_Title.ttf"] },
      { "key": "popupColor", "type": "color", "label": "Cor dos menus (popups)", "group": "Painel", "default": "#f4f1e9" },
      { "key": "logoOffsetX", "type": "text", "label": "Logo — deslocamento horizontal (px)", "group": "Posição interna", "default": "0" },
      { "key": "logoOffsetY", "type": "text", "label": "Logo — distância do topo (px)", "group": "Posição interna", "default": "38" },
      { "key": "formTopMargin", "type": "text", "label": "Formulário — distância do logo (px)", "group": "Posição interna", "default": "35" },
      { "key": "formSideMargin", "type": "text", "label": "Formulário — margem lateral (px)", "group": "Posição interna", "default": "80" },
      { "key": "primaryButtonBg", "type": "image", "label": "Botão principal", "group": "Botão principal", "default": "ui-assets/pc_btn_primary_default.png" },
      { "key": "primaryButtonBgHover", "type": "image", "label": "Botão principal (hover)", "group": "Botão principal", "default": "ui-assets/pc_btn_primary_hover.png" },
      { "key": "primaryButtonBgPressed", "type": "image", "label": "Botão principal (pressionado)", "group": "Botão principal", "default": "ui-assets/pc_btn_primary_pressed.png" },
      { "key": "primaryButtonBgDisabled", "type": "image", "label": "Botão principal (desabilitado)", "group": "Botão principal", "default": "ui-assets/pc_btn_primary_disable.png" },
      { "key": "closeButtonIcon", "type": "image", "label": "Botão fechar", "group": "Botão fechar", "default": "ui-assets/nav_close_default.png" },
      { "key": "closeButtonIconHover", "type": "image", "label": "Botão fechar (hover)", "group": "Botão fechar", "default": "ui-assets/nav_close_hover.png" },
      { "key": "closeButtonIconPressed", "type": "image", "label": "Botão fechar (pressionado)", "group": "Botão fechar", "default": "ui-assets/nav_close_pressed.png" },
      { "key": "powerButtonIcon", "type": "image", "label": "Botão de energia (canto)", "group": "Botões de canto", "default": "ui-assets/title-original/UI_IconSmall_Quit.png", "options": ["ui-assets/icon-power.svg", "ui-assets/title-original/UI_IconSmall_Settings.png"] },
      { "key": "accountButtonIcon", "type": "image", "label": "Botão de conta (canto)", "group": "Botões de canto", "default": "ui-assets/title-original/UI_IconSmall_AddAccount.png", "options": ["ui-assets/icon-account.svg", "ui-assets/title-original/UI_IconSmall_Login.png"] },
      { "key": "sessionButtonIcon", "type": "image", "label": "Botão de sessão (canto)", "group": "Botões de canto", "default": "ui-assets/title-original/UI_IconSmall_Login_Global.png", "options": ["ui-assets/icon-session.svg", "ui-assets/title-original/UI_IconSmall_Notice.png"] },
      { "key": "muteButtonIcon", "type": "image", "label": "Botão de som (ativo)", "group": "Botões de canto", "default": "ui-assets/icon-volume.svg" },
      { "key": "muteButtonIconMuted", "type": "image", "label": "Botão de som (mudo)", "group": "Botões de canto", "default": "ui-assets/icon-muted.svg" },
      { "key": "noticesButtonIcon", "type": "image", "label": "Botão de avisos (canto)", "group": "Botões de canto", "default": "ui-assets/title-original/UI_IconSmall_Notice.png" },
      { "key": "sleepButtonIcon", "type": "image", "label": "Botão de hibernar (canto)", "group": "Botões de canto", "default": "ui-assets/title-original/UI_IconSmall_Hibernate.png" },
      { "key": "journalTabBackground", "type": "image", "label": "Fundo da faixa de abas do painel de avisos", "group": "Painel", "default": "ui-assets/journaltabbackground.png" },
      { "key": "journalBackground", "type": "image", "label": "Fundo do painel de avisos (com conteúdo)", "group": "Painel", "default": "ui-assets/journalbg.png" },
      { "key": "journalBackgroundEmpty", "type": "image", "label": "Fundo do painel de avisos (vazio)", "group": "Painel", "default": "ui-assets/journalbgempty.png" },
      { "key": "journalBanner", "type": "image", "label": "Banner do artigo (aba Notícias)", "group": "Painel", "default": "ui-assets/banner.png" },
      { "key": "modalBackground", "type": "image", "label": "Fundo do modal genérico (ex: esqueci a senha)", "group": "Painel", "default": "ui-assets/modalbackground.png" },
      { "key": "ambientButtonBg", "type": "image", "label": "Barra do seletor de ambiente", "group": "Seletor de ambiente", "default": "ui-assets/ambientmodalbutton.png" },
      { "key": "ambientModalBg", "type": "image", "label": "Fundo do modal de ambiente", "group": "Seletor de ambiente", "default": "ui-assets/ambientmodal.png" },
      { "key": "ambientModalCloseIcon", "type": "image", "label": "Botão fechar do modal de ambiente", "group": "Seletor de ambiente", "default": "ui-assets/ambientmodalclosebtn.png" },
      { "key": "ambientOptionBg", "type": "image", "label": "Linha de opção do modal de ambiente", "group": "Seletor de ambiente", "default": "ui-assets/ambient_modal_option.png" },
      { "key": "startGamePrompt", "type": "image", "label": "Aviso \"Start game\" inicial", "group": "Painel", "default": "ui-assets/start_game.png" },
      { "key": "clickToBeginPrompt", "type": "image", "label": "Texto \"Click to begin\" (pisca)", "group": "Painel", "default": "ui-assets/clicktobegin.png" },
      { "key": "clickSound", "type": "audio", "label": "Som de clique", "group": "Sons", "default": "sounds/switch_task.mp3", "options": ["sounds/close_win.mp3", "sounds/open_win.mp3", "sounds/switch_type.mp3", "sounds/title-back.mp3"] },
      { "key": "openMenuSound", "type": "audio", "label": "Som ao abrir menu", "group": "Sons", "default": "sounds/open_win.mp3", "options": ["sounds/switch_task.mp3", "sounds/close_win.mp3", "sounds/switch_type.mp3", "sounds/title-back.mp3"] },
      { "key": "closeMenuSound", "type": "audio", "label": "Som ao fechar menu", "group": "Sons", "default": "sounds/close_win.mp3", "options": ["sounds/switch_task.mp3", "sounds/open_win.mp3", "sounds/switch_type.mp3", "sounds/title-back.mp3"] },
      { "key": "themeMusic", "type": "audio", "label": "Música tema (mudo/tocando pelo botão de som)", "group": "Sons", "default": "web/Genshin/BGM.mp3", "options": ["sounds/title-back.mp3"] },
      { "key": "ambientSound", "type": "audio", "label": "Som ambiente da cena (não é afetado pelo mudo)", "group": "Sons", "default": "" }
    ]
  },
  "assets": { "audio": [], "textures": [], "materials": [], "shaders": [] },
  "plugins": [],
  "publicApi": ["playAnimation"]
}
